# ──────────────────────────────────────────────────────────────────────
# SVA Consults — Netlify Environment Variables
#
# Add these in Netlify Dashboard:
#   Site Settings → Environment Variables → Add a variable
#
# Do NOT put this file in your repo with real values.
# ──────────────────────────────────────────────────────────────────────

# ── SMTP SETTINGS ──────────────────────────────────────────────────────

# Option A: Gmail with App Password (recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=office@svaconsults.com
SMTP_PASS=your_gmail_app_password_here

# Option B: Hostinger webmail
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=office@svaconsults.com
# SMTP_PASS=your_hostinger_email_password

# Option C: Zoho Mail
# SMTP_HOST=smtp.zoho.in
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=office@svaconsults.com
# SMTP_PASS=your_zoho_password
